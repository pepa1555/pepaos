[global_config]
  focus = system
  title_hide_sibling_tabs = True
[keybindings]
[profiles]
  [[default]]
    cursor_color = "#00d4aa"
    foreground_color = "#cdd6f4"
    background_color = "#0f1923"
    background_darkness = 0.95
    background_type = transparent
    font = JetBrains Mono 10
    show_titlebar = False
    scrollback_infinite = True
    use_system_font = False
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
      maximised = True
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
